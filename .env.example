NEXT_PUBLIC_API_BASE_URL=/api/v1

# Next.js server-side rewrite target (Core API dev port: 3001)
BACKEND_URL=http://localhost:3001
# Browser direct uploads + OAuth + WebSocket — bypasses Next proxy for large files
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_WS_BASE_URL=http://localhost:3001

# NEXT_PUBLIC_ADMIN_EMAILS=you@example.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

NEXT_PUBLIC_ALGOLIA_APP_ID="your-app-id"
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY="your-search-only-api-key"
NEXT_PUBLIC_ALGOLIA_INDEX_NAME="ProductIndex"

# Optional — seller bargain-gap helper text. Defaults to 10 in code if unset.
# NEXT_PUBLIC_BARGAIN_MIN_GAP_PERCENT=10