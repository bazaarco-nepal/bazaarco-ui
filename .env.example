# Browser calls this path; Next proxies to BACKEND_URL (see next.config.ts)
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Core API (bazaarco-api) — server-side rewrite target only
BACKEND_URL=http://localhost:3001

# Socket.IO — use the Next dev server origin so cookies stay same-site
NEXT_PUBLIC_WS_BASE_URL=http://localhost:3000

# Must match Backend FRONTEND_URL and Google redirect URI host (port 3001 in dev)
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# Comma-separated emails allowed to open /seller/admin/verifications (must match Backend ADMIN_EMAILS)
# NEXT_PUBLIC_ADMIN_EMAILS=you@example.com
