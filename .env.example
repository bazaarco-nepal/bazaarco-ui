# Browser calls this path; Next proxies to BACKEND_URL (see next.config.ts)
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Core API (bazaarco-api) — Next.js rewrite target (server) + optional OAuth start URL (browser)
BACKEND_URL=http://localhost:3000
# Production Vercel: https://bazaarco-api.onrender.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# Socket.IO — must point at bazaarco-api (same host as BACKEND_URL), not the Next dev server
NEXT_PUBLIC_WS_BASE_URL=http://localhost:3000

# Must match Backend FRONTEND_URL (port 3001 in dev). In production, set Backend
# GOOGLE_REDIRECT_URI to https://<your-ui-domain>/api/v1/auth/google/callback so
# Google OAuth sets the session cookie on the storefront domain.
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# Comma-separated emails allowed to open /seller/admin/verifications (must match Backend ADMIN_EMAILS)
# NEXT_PUBLIC_ADMIN_EMAILS=you@example.com

# Microsoft Clarity session replay / heatmaps (public project id — safe in client bundle)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Google Analytics 4 measurement id (public — safe in client bundle)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Algolia — browser search (Search-Only API key; never use the Admin/write key here)
NEXT_PUBLIC_ALGOLIA_APP_ID="your-app-id"
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY="your-search-only-api-key"
NEXT_PUBLIC_ALGOLIA_INDEX_NAME="ProductIndex"